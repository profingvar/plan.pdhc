POSTGRES_USER=pdhc_admin
POSTGRES_PASSWORD=CHANGE_ME
# DB name is "pdhc_gateway" — legacy name retained for data continuity
# (rollup #325 / ticket #336). Pre-2026 the service was called
# "PDHC Gateway"; renaming the volume would risk data loss (see
# CLAUDE.md memory feedback_db_safety.md).
POSTGRES_DB=pdhc_gateway
DATABASE_URL=postgresql://pdhc_admin:CHANGE_ME@localhost:9031/pdhc_gateway
FLASK_SECRET_KEY=CHANGE_ME
BOOTSTRAP_SU_USERNAME=admin
BOOTSTRAP_SU_PASSWORD=CHANGE_ME
FLASK_ENV=development
FLASK_PORT=9030
# Set to false for production/SSO deployment
AUTH_DISABLED=true

# Forms builder API key (for external service-to-service access to /api/v1/forms)
API_KEY=change-me-builder-api-key

# SSO integration (used when AUTH_DISABLED=false).
# Local dev: leave AUTH_DISABLED=true above to bypass SSO entirely.
SSO_BASE_URL=https://sso.pdhc.se
SSO_CLIENT_ID=plan_pdhc_local
SSO_CLIENT_SECRET=replace_me
SSO_CALLBACK_URL=http://localhost:9030/api/v1/auth/callback
